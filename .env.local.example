# ── Database (system of record) ────────────────────────────────
# Free Postgres from https://neon.tech — create a project, copy the
# connection string. Without this the app runs in demo mode (in-memory).
DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Google Sheets (import + legacy backup) ─────────────────────
# Service account from Google Cloud Console (see README step 2)
GOOGLE_SERVICE_ACCOUNT_EMAIL=elevate-hub@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"
# The long ID in your sheet URL: docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=1AbC...xyz

# ── Auth (Google sign-in) ──────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=changeme
# OAuth client from Google Cloud Console (see README step 3)
AUTH_GOOGLE_ID=1234567890-abc.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-...
# Bootstrap allowlist (fallback). Day-to-day access is managed on the
# Team page — active members with an email can sign in.
ALLOWED_EMAILS=team@elevatesanantonio.com
